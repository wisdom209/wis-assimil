# Optional browser fallback when src/data/audioUrls.json does not contain a lesson.
VITE_AUDIO_BASE_URL=https://your-cloud-storage.com/assimil/

# Used only by `pnpm upload:audio`; do not expose these in Vite variables.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_AUDIO_FOLDER=assimil-french/audio
